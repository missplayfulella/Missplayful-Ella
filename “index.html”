<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ella | Private & Simple</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:ital,wght@1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #0f0f0f;
            --card-bg: #1a1a1a;
            --text-main: #ffffff;
            --text-muted: #a0a0a0;
            --accent: #ccff00;
            --accent-hover: #b3e600;
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        a { text-decoration: none; color: inherit; }
        ul { list-style: none; }

        /* Header */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1.5rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(15, 15, 15, 0.9);
            backdrop-filter: blur(10px);
            z-index: 1000;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            color: var(--text-main);
        }

        .logo span { color: var(--accent); }

        nav ul {
            display: flex;
            gap: 2rem;
        }

        nav a {
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: var(--transition);
        }

        nav a:hover { color: var(--accent); }

        .mobile-toggle { display: none; cursor: pointer; font-size: 1.5rem; }

        /* Hero */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8rem 5% 4rem;
            position: relative;
        }

        .hero-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            max-width: 800px;
            width: 100%;
            gap: 2rem;
        }

        .hero-content h1 {
            font-size: 4rem;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            font-weight: 800;
        }

        .hero-content h1 span {
            color: var(--accent);
            font-style: italic;
            font-family: 'Playfair Display', serif;
        }

        .hero-content p {
            font-size: 1.2rem;
            color: var(--text-muted);
            margin-bottom: 2.5rem;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .cta-group {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        .btn {
            padding: 1rem 2rem;
            border-radius: 50px;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.9rem;
            transition: var(--transition);
            cursor: pointer;
            border: none;
        }

        .btn-primary {
            background-color: var(--accent);
            color: #000;
        }

        .btn-primary:hover {
            background-color: var(--accent-hover);
            transform: translateY(-2px);
        }

        .btn-outline {
            border: 2px solid var(--text-main);
            background: transparent;
            color: var(--text-main);
        }

        .btn-outline:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        /* Sections */
        .section {
            padding: 6rem 5%;
            max-width: 1000px;
            margin: 0 auto;
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .section-header h2 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .section-header .line {
            width: 60px;
            height: 4px;
            background-color: var(--accent);
            margin: 0 auto;
        }

        .about-text {
            font-size: 1.1rem;
            color: var(--text-muted);
            text-align: center;
            max-width: 700px;
            margin: 0 auto;
        }

        /* How It Works */
        .steps-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .step-card {
            background: var(--card-bg);
            padding: 2.5rem;
            border-radius: 15px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.05);
            transition: var(--transition);
        }

        .step-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent);
        }

        .step-number {
            font-size: 3rem;
            font-weight: 800;
            color: rgba(255,255,255,0.1);
            margin-bottom: 1rem;
            display: block;
        }

        .step-card h3 {
            margin-bottom: 1rem;
            color: var(--text-main);
        }

        .step-card p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Guidelines */
        .guidelines-container {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 3rem;
            border: 1px solid rgba(255,255,255,0.05);
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
            align-items: center;
        }

        .guidelines-content {
            flex: 1;
            min-width: 300px;
        }

        .guidelines-list li {
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            color: var(--text-muted);
        }

        .guidelines-list li::before {
            content: '✓';
            color: var(--accent);
            font-weight: bold;
        }

        .guidelines-highlight {
            flex: 1;
            min-width: 300px;
            background: rgba(204, 255, 0, 0.1);
            padding: 2rem;
            border-radius: 15px;
            border-left: 4px solid var(--accent);
        }

        /* Contact */
        .contact-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            background: var(--card-bg);
            padding: 3rem;
            border-radius: 20px;
        }

        .contact-info h3 {
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
        }

        .contact-email {
            font-size: 1.2rem;
            color: var(--accent);
            margin-bottom: 2rem;
            display: block;
            font-weight: 600;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .form-control {
            width: 100%;
            padding: 1rem;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: var(--text-main);
            font-family: inherit;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--accent);
        }

        textarea.form-control {
            resize: vertical;
            min-height: 120px;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 3rem 5%;
            border-top: 1px solid rgba(255,255,255,0.05);
            margin-top: 4rem;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        /* Responsive */
        @media (max-width: 900px) {
            .hero-content h1 { font-size: 3rem; }
            .contact-wrapper { grid-template-columns: 1fr; gap: 2rem; }
        }

        @media (max-width: 768px) {
            nav ul { display: none; }
            .mobile-toggle { display: block; }
            .hero-content h1 { font-size: 2.5rem; }
            .guidelines-container { flex-direction: column; }
        }

        /* Animations */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.6s ease-out, transform 0.6s ease-out;
        }
        
        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body>

    <header>
        <div class="logo">ELLA<span>.</span></div>
        <nav>
            <ul>
                <li><a href="#about">About</a></li>
                <li><a href="#how-it-works">How It Works</a></li>
                <li><a href="#guidelines">Guidelines</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
        <div class="mobile-toggle">☰</div>
    </header>

    <section class="hero">
        <div class="hero-container">
            <div class="hero-content fade-in">
                <h1>Meet Ella.<br><span>Keep It Private.</span></h1>
                <p>Looking for a real connection without the noise? You're in the right place. I keep things simple, direct, and between us.</p>
                <div class="cta-group">
                    <a href="#contact" class="btn btn-primary">💬 Reach Out Now</a>
                    <a href="#about" class="btn btn-outline">🔥 Let's Connect</a>
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="section">
        <div class="section-header fade-in">
            <h2>About Me</h2>
            <div class="line"></div>
        </div>
        <div class="about-text fade-in">
            <p style="margin-bottom: 1.5rem;">Hey, I'm Ella. I'm open-minded, fun, and enjoy meeting new people who know what they want. If you're respectful, confident, and serious about connecting, we'll get along just fine.</p>
            <p>I value privacy, honesty, and good vibes—everything else we can figure out together.</p>
        </div>
    </section>

    <section id="how-it-works" class="section">
        <div class="section-header fade-in">
            <h2>How It Works</h2>
            <div class="line"></div>
        </div>
        <div class="steps-grid">
            <div class="step-card fade-in">
                <span class="step-number">01</span>
                <h3>Reach Out</h3>
                <p>Send me a message introducing yourself. Tell me a bit about what you're looking for.</p>
            </div>
            <div class="step-card fade-in">
                <span class="step-number">02</span>
                <h3>Connect</h3>
                <p>We chat and see if we vibe. I appreciate people who know how to communicate.</p>
            </div>
            <div class="step-card fade-in">
                <span class="step-number">03</span>
                <h3>Keep It Private</h3>
                <p>Anything beyond that is discussed privately between us. Discretion is key.</p>
            </div>
        </div>
    </section>

    <section id="guidelines" class="section">
        <div class="guidelines-container fade-in">
            <div class="guidelines-content">
                <h2 style="margin-bottom: 1.5rem;">Guidelines</h2>
                <ul class="guidelines-list">
                    <li>18+ only</li>
                    <li>Be respectful and direct</li>
                    <li>No time-wasters</li>
                    <li>Discretion is important</li>
                </ul>
            </div>
            <div class="guidelines-highlight">
                <p style="font-size: 1.1rem; font-weight: 600; color: var(--text-main);">"If you're genuine, you'll get my attention."</p>
                <p style="margin-top: 1rem; font-size: 0.9rem; color: var(--text-muted);">I appreciate people who respect boundaries and keep things simple and drama-free.</p>
            </div>
        </div>
    </section>

    <section id="contact" class="section">
        <div class="contact-wrapper fade-in">
            <div class="contact-info">
                <h3>Get In Touch</h3>
                <p style="margin-bottom: 2rem; color: var(--text-muted);">Serious inquiries only. Tell me a bit about yourself when you reach out.</p>
                
                <span class="contact-email">📧 missplayfulella@gmail.com</span>
                
                <div style="margin-top: 2rem;">
                    <p style="font-weight: 600; margin-bottom: 0.5rem;">Ready to connect?</p>
                    <p style="font-size: 0.9rem; color: var(--text-muted);">Send me a message and let's see where it goes.</p>
                </div>
            </div>
            
            <form class="contact-form" onsubmit="event.preventDefault(); alert('Message sent! (Demo)');">
                <div class="form-group">
                    <label>Name</label>
                    <input type="text" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>Message</label>
                    <textarea class="form-control" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%;">Send Message</button>
            </form>
        </div>
    </section>

    <footer>
        <p>&copy; 2024 Ella. Private. Simple. Real.</p>
    </footer>

    <script>
        // Smooth Scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Fade-in Animation
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-in').forEach(el => {
            observer.observe(el);
        });

        // Mobile Menu
        const mobileToggle = document.querySelector('.mobile-toggle');
        const nav = document.querySelector('nav ul');

        mobileToggle.addEventListener('click', () => {
            if (nav.style.display === 'flex') {
                nav.style.display = 'none';
            } else {
                nav.style.display = 'flex';
                nav.style.flexDirection = 'column';
                nav.style.position = 'absolute';
                nav.style.top = '70px';
                nav.style.left = '0';
                nav.style.width = '100%';
                nav.style.background = '#0f0f0f';
                nav.style.padding = '2rem';
                nav.style.borderBottom = '1px solid rgba(255,255,255,0.1)';
            }
        });
    </script>
</body>
</html>